---
// Simplified Clinical Footer component
---

<footer class="footer-section">
  <div class="container">
    <div class="footer-grid">
      <!-- Left side: Brand and Medical Disclaimer -->
      <div class="footer-brand-col">
        <a href="#" class="footer-logo">
          <div class="logo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <span class="logo-text">MediMind <span class="text-teal">AI</span></span>
        </a>
        <p class="body-sm footer-disclaimer">
          <strong>Important Clinical Notice:</strong> MediMind AI is an informational symptom-screening tool designed to provide preliminary health guidance. This platform does not provide formal medical diagnoses, write certified prescriptions, or replace in-person physician advice. In the event of serious symptoms, severe chest tightness, or clinical emergencies, immediately contact emergency services or visit the nearest hospital.
        </p>
      </div>

      <!-- Right side: Quick Policy Actions -->
      <div class="footer-policies-col">
        <span class="caption-mono policy-label">Regulatory Declarations</span>
        <div class="policy-links-list">
          <a href="#" class="policy-link">HIPAA Security Disclosure</a>
          <a href="#" class="policy-link">Data Privacy Policy</a>
          <a href="#" class="policy-link">User Terms & Conditions</a>
          <a href="#" class="policy-link">Clinical Database Audits</a>
        </div>
      </div>
    </div>

    <!-- Footer Copyright -->
    <div class="footer-bottom">
      <p class="caption footer-copy text-left">
        Copyright © 2026 MediMind AI. All rights reserved. Developed for portfolios.
      </p>
      <span class="caption-mono font-xs label-teal">E2E Encrypted HIPAA Safe</span>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    background-color: var(--color-canvas);
    border-top: 1px solid var(--color-canvas-soft-2);
    padding: var(--space-3xl) 0 var(--space-xl) 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-4xl);
    margin-bottom: var(--space-3xl);
  }

  .footer-brand-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
    text-align: left;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--color-ink);
  }

  .footer-logo .logo-icon {
    width: 28px;
    height: 28px;
    background: var(--gradient-blue-teal);
    border-radius: var(--radius-sm);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-logo .logo-icon svg {
    transform: rotate(45deg);
  }

  .logo-text {
    font-family: var(--font-sans);
  }

  .text-teal {
    color: var(--color-accent);
  }

  .footer-disclaimer {
    color: var(--color-mute);
    font-size: 0.775rem;
    line-height: 1.5;
    max-width: 620px;
  }

  /* Policies Column */
  .footer-policies-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
    text-align: left;
  }

  .policy-label {
    font-size: 0.7rem;
    color: var(--color-ink);
    margin-bottom: 2px;
  }

  .policy-links-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .policy-link {
    text-decoration: none;
    font-size: 0.8rem;
    color: var(--color-body);
    transition: var(--transition-smooth);
  }

  .policy-link:hover {
    color: var(--color-primary);
    transform: translateX(2px);
  }

  /* Bottom copyright band */
  .footer-bottom {
    border-top: 1px solid var(--color-canvas-soft-2);
    padding-top: var(--space-xl);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy {
    color: var(--color-mute);
  }

  .label-teal {
    color: var(--color-accent);
  }

  /* Responsive layout */
  @media (max-width: 959px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 600px) {
    .footer-bottom {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }

    .footer-copy {
      text-align: center !important;
    }
  }
</style>
