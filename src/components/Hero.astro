---
// Hero.astro
---

<section class="hero-section">
  <!-- Atmospheric background mesh gradient -->
  <div class="mesh-glow"></div>

  <div class="container hero-container">
    <div class="hero-content">
      <!-- Announcement Badge -->
      <div class="announcement">
        <span class="badge badge-teal animate-pulse-soft">
          <span class="pulse-dot"></span>
          Now Live: MediMind AI v1.0
        </span>
      </div>

      <!-- Headline (Sentence-case, period-terminated, negative spacing) -->
      <h1 class="display-xl hero-title">
        Your personal AI health assistant.
      </h1>

      <!-- Subheading -->
      <p class="body-lg hero-subtitle">
        Monitor your health, check symptoms, manage medications, book appointments, and access your medical records—all powered by Artificial Intelligence.
      </p>

      <!-- CTA buttons -->
      <div class="hero-ctas">
        <a href="dashboard.html" class="btn btn-lg btn-primary">
          Get Started
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <a href="#live-checker" class="btn btn-lg btn-secondary outline-btn">
          Try AI Symptom Checker
        </a>
      </div>


      <!-- Trust Badges (Mini-list matching startup layout) -->
      <div class="trust-list">
        <div class="trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="caption-mono font-xs">HIPAA Compliant</span>
        </div>
        <div class="trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="caption-mono font-xs">256-bit Encrypted</span>
        </div>
        <div class="trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="caption-mono font-xs">Clinical Grade AI</span>
        </div>
      </div>
    </div>

    <!-- Right-hand side illustration visual -->
    <div class="hero-visual">
      <div class="mockup-wrapper animate-float">
        <div class="glass-reflection"></div>
        <div class="mockup-frame">
          <div class="mockup-screen">
            <img 
              src="/ai-doctor-dashboard.png" 
              alt="MediMind AI Doctor dashboard mockup showing heart-rate pulse graphs and medication reminders" 
              class="hero-img"
              loading="eager"
            />
          </div>
        </div>
        
        <!-- Floating glassmorphic widgets for visual depth -->
        <div class="floating-widget widget-heart-rate glass-card">
          <div class="widget-header">
            <div class="widget-icon red-glow">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div>
              <span class="widget-label">Pulse</span>
              <h4 class="widget-value">72 BPM</h4>
            </div>
          </div>
          <span class="widget-status text-teal">Normal</span>
        </div>

        <div class="floating-widget widget-alert glass-card">
          <div class="widget-header">
            <div class="widget-icon teal-glow">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
            </div>
            <div>
              <span class="widget-label">Medication</span>
              <h4 class="widget-value text-sm">Amoxicillin</h4>
            </div>
          </div>
          <span class="widget-status font-mono">10:00 AM</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    padding-top: 140px;
    padding-bottom: var(--space-5xl);
    overflow: hidden;
    background-color: var(--color-canvas);
  }

  .mesh-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--gradient-mesh);
    z-index: 1;
    pointer-events: none;
  }

  .hero-container {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .announcement {
    margin-bottom: var(--space-lg);
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background-color: var(--color-accent);
    border-radius: 50%;
    display: inline-block;
  }

  .hero-title {
    color: var(--color-ink);
    margin-bottom: var(--space-md);
    max-width: 580px;
  }

  .hero-subtitle {
    margin-bottom: var(--space-2xl);
    max-width: 520px;
    color: var(--color-body);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    width: 100%;
  }

  .outline-btn {
    border: 1px solid var(--color-canvas-soft-2);
  }

  .trust-list {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .font-xs {
    font-size: 0.65rem !important;
    color: var(--color-body);
  }

  /* Image Visual & Widget Container */
  .hero-visual {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .mockup-wrapper {
    position: relative;
    width: 100%;
    max-width: 440px;
  }

  .mockup-frame {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    padding: var(--space-sm);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-level-5), 0 20px 40px rgba(37, 99, 235, 0.05);
  }

  .mockup-screen {
    border-radius: calc(var(--radius-2xl) - 8px);
    overflow: hidden;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background-color: var(--color-canvas-soft);
    aspect-ratio: 4/5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .glass-reflection {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, transparent 50%);
    z-index: 5;
    pointer-events: none;
    border-radius: var(--radius-2xl);
  }

  /* Floating Widgets */
  .floating-widget {
    position: absolute;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    z-index: 6;
  }

  .widget-heart-rate {
    bottom: var(--space-xl);
    left: -40px;
    animation: float 5s ease-in-out infinite alternate;
  }

  .widget-alert {
    top: var(--space-2xl);
    right: -40px;
    animation: float 6s ease-in-out infinite alternate 1s;
  }

  .widget-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .widget-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .red-glow {
    background-color: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }

  .teal-glow {
    background-color: rgba(20, 184, 166, 0.1);
    color: var(--color-accent);
  }

  .widget-label {
    font-size: 0.65rem;
    color: var(--color-mute);
    display: block;
  }

  .widget-value {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .text-sm {
    font-size: 0.8rem;
  }

  .widget-status {
    font-size: 0.7rem;
    font-weight: 500;
  }

  /* Responsive breakpoints */
  @media (max-width: 959px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: var(--space-3xl);
      text-align: center;
    }

    .hero-content {
      align-items: center;
    }

    .hero-title, .hero-subtitle {
      max-width: 100%;
    }

    .hero-ctas {
      justify-content: center;
    }

    .trust-list {
      justify-content: center;
    }

    .hero-visual {
      margin-top: var(--space-xl);
    }
  }

  @media (max-width: 600px) {
    .hero-section {
      padding-top: 100px;
    }

    .hero-ctas {
      flex-direction: column;
      gap: var(--space-sm);
    }

    .floating-widget {
      display: none; /* Hide floating widgets on small screens to save space */
    }
  }
</style>
