---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="MediMind AI – Patient Vitals Dashboard">
  <Header />
  
  <main class="dashboard-page section">
    <div class="lc-bg-glow"></div>
    <div class="container">
      
      <!-- Page Header -->
      <div class="db-page-header">
        <div>
          <span class="badge badge-teal animate-pulse-soft">Vitals Portal</span>
          <h1 class="display-lg page-title">Patient Health Summary</h1>
          <p class="body-md page-subtitle text-slate">John Doe · Male, 34 yrs · Patient ID: #MM-3094</p>
        </div>
        <div class="db-actions">
          <button class="btn btn-primary" id="openLogModalBtn" style="font-size: 0.85rem; padding: 8px 16px;">⚡ Log / Upload Vitals</button>
        </div>
      </div>

      <!-- Vitals Dashboard Grid -->
      <div class="vitals-grid">
        <!-- Heart Rate Card -->
        <div class="glass-card vital-card">
          <div class="vital-card-header">
            <span class="vital-label">Heart Rate</span>
            <span class="vital-icon pulse-animation">❤️</span>
          </div>
          <div class="vital-value-group">
            <span class="vital-value" id="dbLiveBpm">72</span>
            <span class="vital-unit">BPM</span>
          </div>
          <div class="vital-chart-box">
            <svg viewBox="0 0 100 24" class="vital-chart-svg">
              <path d="M 0,12 L 20,12 L 25,2 L 30,22 L 35,12 L 50,12 L 55,2 L 60,22 L 65,12 L 80,12 L 85,12 L 90,2 L 95,22 L 100,12" fill="none" stroke="var(--color-primary)" stroke-width="2" class="heart-line-path"></path>
            </svg>
          </div>
          <span class="vital-status text-teal">Resting · Stable</span>
        </div>

        <!-- Blood Pressure Card -->
        <div class="glass-card vital-card">
          <div class="vital-card-header">
            <span class="vital-label">Blood Pressure</span>
            <span class="vital-icon text-teal">🩸</span>
          </div>
          <div class="vital-value-group">
            <span class="vital-value" id="dbLiveBp">120/80</span>
            <span class="vital-unit">mmHg</span>
          </div>
          <div class="vital-progress">
            <div class="progress-bar-fill bg-teal" id="dbBpProgress" style="width: 80%"></div>
          </div>
          <span class="vital-status text-teal" id="dbBpStatus">Optimal Condition</span>
        </div>

        <!-- Blood Sugar Card -->
        <div class="glass-card vital-card">
          <div class="vital-card-header">
            <span class="vital-label">Blood Sugar</span>
            <span class="vital-icon text-amber">🍬</span>
          </div>
          <div class="vital-value-group">
            <span class="vital-value" id="dbLiveSugar">95</span>
            <span class="vital-unit">mg/dL</span>
          </div>
          <div class="vital-progress">
            <div class="progress-bar-fill bg-amber" id="dbSugarProgress" style="width: 65%"></div>
          </div>
          <span class="vital-status text-amber" id="dbSugarStatus">Normal (Fasting)</span>
        </div>

        <!-- Blood Oxygen Card -->
        <div class="glass-card vital-card">
          <div class="vital-card-header">
            <span class="vital-label">Blood Oxygen</span>
            <span class="vital-icon text-blue">🫁</span>
          </div>
          <div class="vital-value-group">
            <span class="vital-value" id="dbLiveSpO2">98%</span>
            <span class="vital-unit">SpO2</span>
          </div>
          <div class="vital-progress">
            <div class="progress-bar-fill bg-blue" id="dbSpO2Progress" style="width: 98%"></div>
          </div>
          <span class="vital-status text-teal" id="dbSpO2Status">Healthy Oxygenation</span>
        </div>
      </div>

      <!-- Bottom Layout split: Tables & Chatbot -->
      <div class="dashboard-split-grid">
        <!-- Left Side: Table & Meds -->
        <div class="db-data-side">
          <!-- Vitals Log Table -->
          <div class="glass-card table-section">
            <div class="db-section-header">
              <h3 class="display-sm db-sec-title">Vitals Log History</h3>
              <span class="caption-mono font-xs">Monthly Log</span>
            </div>
            <div class="vitals-table-wrapper">
              <table class="vitals-table">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Pulse</th>
                    <th>Systolic/Diastolic</th>
                    <th>Fasting Glucose</th>
                    <th>SpO2</th>
                  </tr>
                </thead>
                <tbody id="vitalsTableBody">
                  <tr>
                    <td>June 26, 2026</td>
                    <td>72 BPM</td>
                    <td>120/80</td>
                    <td>95 mg/dL</td>
                    <td>98%</td>
                  </tr>
                  <tr>
                    <td>June 25, 2026</td>
                    <td>74 BPM</td>
                    <td>122/81</td>
                    <td>98 mg/dL</td>
                    <td>99%</td>
                  </tr>
                  <tr>
                    <td>June 24, 2026</td>
                    <td>70 BPM</td>
                    <td>118/79</td>
                    <td>92 mg/dL</td>
                    <td>98%</td>
                  </tr>
                  <tr>
                    <td>June 23, 2026</td>
                    <td>75 BPM</td>
                    <td>124/82</td>
                    <td>102 mg/dL</td>
                    <td>97%</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>


        </div>

        <!-- Right Side: Interactive AI Coach Chatbot -->
        <div class="db-chat-side">
          <div class="glass-card chat-console">
            <div class="chat-header">
              <div class="chat-logo-group">
                <div class="chat-logo-icon">🤖</div>
                <div>
                  <h4 class="chat-title">AI Health Coach</h4>
                  <span class="caption-mono font-xs label-teal">Active Counsel Engine</span>
                </div>
              </div>
              <span class="badge badge-teal font-mono font-xs">Online</span>
            </div>

            <!-- Messages Window -->
            <div class="chat-messages-box" id="chatMessages">
              <div class="chat-msg msg-ai">
                <div class="msg-avatar">🤖</div>
                <div class="msg-bubble">
                  Hello John! I'm your MediMind AI Health Coach. I have parsed your active vitals (Pulse: 72, BP: 120/80). How can I assist you with wellness or medicine advice today?
                </div>
              </div>
            </div>

            <!-- Chat Suggestions -->
            <div class="chat-suggestions-box">
              <span class="suggestions-lbl">Click to ask Coach:</span>
              <div class="suggestions-list">
                <button class="chat-suggest-btn" data-query="How can I lower my blood sugar naturally?">Lower Blood Sugar</button>
                <button class="chat-suggest-btn" data-query="Recommend a heart-healthy meal plan.">Healthy Diet Plan</button>
                <button class="chat-suggest-btn" data-query="What is my blood pressure trend?">Assess BP Trend</button>
              </div>
            </div>

            <!-- Input area -->
            <form class="chat-input-row" id="chatForm">
              <input type="text" id="chatInputText" required class="form-control chat-input" placeholder="Ask about medications, diets, or vitals..." aria-label="Ask Chatbot Input" />
              <button type="submit" class="btn btn-primary chat-send-btn" aria-label="Send message button">
                Send
              </button>
            </form>
          </div>
        </div>
      </div>

    </div>
  </main>

  <!-- Vitals Logging / Ingestion Modal -->
  <div class="modal-overlay hide" id="vitalsLogModal">
    <div class="modal-card glass-card">
      <div class="modal-header">
        <h3 class="modal-title">Log / Upload Patient Vitals</h3>
        <button class="modal-close" id="closeVitalsModalBtn">×</button>
      </div>
      
      <div class="modal-body">
        <!-- Tabs -->
        <div class="modal-tabs-header">
          <button class="modal-tab-btn active" id="tabManualBtn">✏️ Manual Input</button>
          <button class="modal-tab-btn" id="tabUploadBtn">📂 File Ingestion</button>
        </div>

        <!-- Manual Tab Content -->
        <div class="tab-content" id="tabManualContent">
          <form id="manualVitalsForm">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md);">
              <div class="form-group">
                <label class="form-label" for="inputBpm">Heart Rate (BPM)</label>
                <input type="number" id="inputBpm" class="form-control" placeholder="e.g. 72" required min="40" max="200" value="72" />
              </div>
              <div class="form-group">
                <label class="form-label" for="inputBp">Blood Pressure</label>
                <input type="text" id="inputBp" class="form-control" placeholder="e.g. 120/80" required pattern="^[0-9]{2,3}\/[0-9]{2,3}$" value="120/80" />
              </div>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); margin-top: var(--space-xs);">
              <div class="form-group">
                <label class="form-label" for="inputSugar">Blood Sugar (mg/dL)</label>
                <input type="number" id="inputSugar" class="form-control" placeholder="e.g. 95" required min="50" max="400" value="95" />
              </div>
              <div class="form-group">
                <label class="form-label" for="inputSpO2">Blood Oxygen (SpO2 %)</label>
                <input type="number" id="inputSpO2" class="form-control" placeholder="e.g. 98" required min="70" max="100" value="98" />
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" id="cancelManualBtn">Cancel</button>
              <button type="submit" class="btn btn-primary">Save Vitals</button>
            </div>
          </form>
        </div>

        <!-- Upload Tab Content -->
        <div class="tab-content hide" id="tabUploadContent">
          <div class="modal-dropzone" id="vitalsDropzone">
            <span style="font-size: 2rem;">📊</span>
            <p class="body-sm" style="margin: 4px 0;"><strong>Drag & drop vitals log file</strong>, or click to browse</p>
            <span class="caption">Supports CSV or JSON exports from smartwatches or clinical portals</span>
            <input type="file" id="vitalsFileInput" class="hide-file-input" accept=".csv,.json" />
          </div>
          
          <div class="ingest-progress-box hide" id="vitalsUploadProgress" style="margin-top: var(--space-sm);">
            <div class="progress-info-row">
              <span class="caption-mono font-xs label-teal" id="vitalsUploadStatus">Ingesting log...</span>
              <span class="caption-mono font-xs" id="vitalsUploadPct">0%</span>
            </div>
            <div class="progress-bar-outer" style="margin-top: 4px;">
              <div class="progress-bar-inner" id="vitalsUploadBar" style="width: 0%;"></div>
            </div>
          </div>
          
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" id="cancelUploadBtn">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .dashboard-page {
    padding-top: 110px;
    background-color: var(--color-canvas-soft);
    position: relative;
    overflow: hidden;
  }

  .lc-bg-glow {
    position: absolute;
    top: 5%;
    left: -5%;
    width: 350px;
    height: 350px;
    background-color: rgba(37, 99, 235, 0.05);
    filter: blur(120px);
    pointer-events: none;
    border-radius: 50%;
  }

  /* Header status */
  .db-page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-bottom: 1px solid var(--color-canvas-soft-2);
    padding-bottom: var(--space-md);
    margin-bottom: var(--space-xl);
    text-align: left;
  }

  .page-title {
    margin-bottom: 4px;
  }

  .db-sync-status {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    background-color: rgba(20, 184, 166, 0.06);
    border: 1px solid rgba(20, 184, 166, 0.15);
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-xs);
  }

  .sync-indicator {
    width: 6px;
    height: 6px;
    background-color: var(--color-accent);
    border-radius: 50%;
  }

  .pulse-green {
    animation: statusPulse 1.8s infinite;
  }

  /* Vitals Card Grid */
  .vitals-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .vital-card {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    background-color: var(--color-canvas);
  }

  .vital-card-header {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xs);
  }

  .vital-label {
    font-size: 0.75rem;
    color: var(--color-mute);
    font-weight: 500;
  }

  .vital-icon {
    font-size: 0.85rem;
  }

  .pulse-animation {
    animation: pulseIcon 1.2s infinite;
    display: inline-block;
  }

  .vital-value-group {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: var(--space-xs);
  }

  .vital-value {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .vital-unit {
    font-size: 0.75rem;
    color: var(--color-mute);
  }

  .vital-progress {
    width: 100%;
    height: 4px;
    background-color: var(--color-canvas-soft-2);
    border-radius: var(--radius-full);
    overflow: hidden;
    margin-bottom: var(--space-xs);
  }

  .progress-bar-fill {
    height: 100%;
  }

  .bg-teal { background-color: var(--color-accent); }
  .bg-amber { background-color: var(--color-warning); }
  .bg-blue { background-color: var(--color-primary); }

  .vital-chart-box {
    width: 100%;
    height: 24px;
    margin-bottom: var(--space-xs);
  }

  .vital-chart-svg {
    width: 100%;
    height: 100%;
  }

  .heart-line-path {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: drawPulseLine 3s linear infinite;
  }

  .vital-status {
    font-size: 0.65rem;
    font-weight: 500;
  }

  /* Bottom Split Dashboard layout */
  .dashboard-split-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .db-data-side {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .db-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-canvas-soft-2);
    padding-bottom: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .db-sec-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  /* Table Style */
  .table-section {
    padding: var(--space-md);
    background-color: var(--color-canvas);
  }

  .vitals-table-wrapper {
    overflow-x: auto;
  }

  .vitals-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.775rem;
    color: var(--color-body);
  }

  .vitals-table th {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-mute);
    padding: var(--space-sm);
    text-align: left;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-canvas-soft-2);
  }

  .vitals-table td {
    padding: var(--space-md) var(--space-sm);
    border-bottom: 1px solid rgba(15, 23, 42, 0.04);
    text-align: left;
  }



  /* Chat Side Console */
  .chat-console {
    background-color: var(--color-canvas);
    padding: var(--space-md);
    min-height: 480px;
    display: flex;
    flex-direction: column;
  }

  .chat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-canvas-soft-2);
    padding-bottom: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .chat-logo-group {
    display: flex;
    align-items: center;
    gap: 8px;
    text-align: left;
  }

  .chat-logo-icon {
    font-size: 1.15rem;
  }

  .chat-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .chat-messages-box {
    flex-grow: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-height: 280px;
    margin-bottom: var(--space-md);
    padding: 2px;
  }

  .chat-msg {
    display: flex;
    gap: var(--space-xs);
    align-items: flex-start;
  }

  .msg-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: rgba(37, 99, 235, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .msg-bubble {
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-canvas-soft-2);
    padding: var(--space-sm);
    border-radius: var(--radius-lg);
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--color-body);
    text-align: left;
    max-width: 85%;
  }

  .msg-patient {
    flex-direction: row-reverse;
  }

  .msg-patient .msg-avatar {
    background-color: rgba(20, 184, 166, 0.08);
  }

  .msg-patient .msg-bubble {
    background-color: rgba(37, 99, 235, 0.05);
    border-color: rgba(37, 99, 235, 0.1);
    color: var(--color-ink);
  }

  /* Suggestions */
  .chat-suggestions-box {
    margin-bottom: var(--space-sm);
    text-align: left;
  }

  .suggestions-lbl {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-mute);
    display: block;
    margin-bottom: 4px;
  }

  .suggestions-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .chat-suggest-btn {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 500;
    padding: 4px 10px;
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-canvas-soft-2);
    color: var(--color-body);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .chat-suggest-btn:hover {
    background-color: rgba(37, 99, 235, 0.05);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* Input form */
  .chat-input-row {
    display: flex;
    gap: 6px;
    margin-top: auto;
  }

  .chat-input {
    flex-grow: 1;
    height: 38px;
    font-size: 0.8rem;
    padding: 0 var(--space-md);
  }

  .chat-send-btn {
    height: 38px;
    padding: 0 var(--space-md);
  }

  /* Animations */
  @keyframes pulseIcon {
    0% { transform: scale(1); }
    30% { transform: scale(1.15); }
    60% { transform: scale(1); }
  }

  @keyframes drawPulseLine {
    to { stroke-dashoffset: 0; }
  }

  /* Responsive styling */
  @media (max-width: 959px) {
    .vitals-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .dashboard-split-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 600px) {
    .vitals-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Modal Styles */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15, 23, 42, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    animation: fadeIn 0.25s ease;
  }

  .modal-card {
    width: 90%;
    max-width: 480px;
    background: var(--color-canvas);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.7);
    box-shadow: var(--shadow-level-5);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-canvas-soft-2);
    padding-bottom: var(--space-sm);
  }

  .modal-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .modal-close {
    font-size: 1.5rem;
    color: var(--color-mute);
    cursor: pointer;
    background: none;
    border: none;
    line-height: 1;
  }

  .modal-close:hover {
    color: var(--color-ink);
  }

  .modal-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .modal-tabs-header {
    display: flex;
    border-bottom: 1px solid var(--color-canvas-soft-2);
    margin-bottom: var(--space-xs);
  }

  .modal-tab-btn {
    padding: 8px 16px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-mute);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .modal-tab-btn.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
    font-weight: 600;
  }

  .tab-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* File uploader dropzone */
  .modal-dropzone {
    border: 2px dashed var(--color-canvas-soft-2);
    background-color: var(--color-canvas-soft);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    text-align: center;
    cursor: pointer;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .modal-dropzone:hover, .modal-dropzone.dragover {
    border-color: var(--color-primary);
    background-color: rgba(37, 99, 235, 0.03);
  }

  .modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-sm);
    border-top: 1px solid var(--color-canvas-soft-2);
    padding-top: var(--space-sm);
    margin-top: var(--space-xs);
  }
</style>

<script>
  // Modal toggle functionality
  const openLogModalBtn = document.getElementById('openLogModalBtn');
  const vitalsLogModal = document.getElementById('vitalsLogModal');
  const closeVitalsModalBtn = document.getElementById('closeVitalsModalBtn');
  const cancelManualBtn = document.getElementById('cancelManualBtn');
  const cancelUploadBtn = document.getElementById('cancelUploadBtn');

  function openVitalsModal() {
    vitalsLogModal?.classList.remove('hide');
  }

  function closeVitalsModal() {
    vitalsLogModal?.classList.add('hide');
    resetVitalsForm();
  }

  if (openLogModalBtn) openLogModalBtn.addEventListener('click', openVitalsModal);
  if (closeVitalsModalBtn) closeVitalsModalBtn.addEventListener('click', closeVitalsModal);
  if (cancelManualBtn) cancelManualBtn.addEventListener('click', closeVitalsModal);
  if (cancelUploadBtn) cancelUploadBtn.addEventListener('click', closeVitalsModal);

  // Tab toggling
  const tabManualBtn = document.getElementById('tabManualBtn');
  const tabUploadBtn = document.getElementById('tabUploadBtn');
  const tabManualContent = document.getElementById('tabManualContent');
  const tabUploadContent = document.getElementById('tabUploadContent');

  if (tabManualBtn && tabUploadBtn && tabManualContent && tabUploadContent) {
    tabManualBtn.addEventListener('click', () => {
      tabManualBtn.classList.add('active');
      tabUploadBtn.classList.remove('active');
      tabManualContent.classList.remove('hide');
      tabUploadContent.classList.add('hide');
    });

    tabUploadBtn.addEventListener('click', () => {
      tabUploadBtn.classList.add('active');
      tabManualBtn.classList.remove('active');
      tabUploadContent.classList.remove('hide');
      tabManualContent.classList.add('hide');
    });
  }

  // Manual Form Submission
  const manualVitalsForm = document.getElementById('manualVitalsForm');
  const vitalsTableBody = document.getElementById('vitalsTableBody');

  if (manualVitalsForm) {
    manualVitalsForm.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const bpm = document.getElementById('inputBpm').value;
      const bp = document.getElementById('inputBp').value;
      const sugar = document.getElementById('inputSugar').value;
      const spo2 = document.getElementById('inputSpO2').value;

      updateVitalsDisplay(bpm, bp, sugar, spo2);
      insertVitalsTableRow(bpm, bp, sugar, spo2);
      closeVitalsModal();
    });
  }

  // Update DOM elements for vitals display
  function updateVitalsDisplay(bpm, bp, sugar, spo2) {
    // Heart Rate
    const liveBpmEl = document.getElementById('dbLiveBpm');
    if (liveBpmEl) liveBpmEl.innerText = bpm;

    // Blood Pressure
    const liveBpEl = document.getElementById('dbLiveBp');
    const bpProgressEl = document.getElementById('dbBpProgress');
    const bpStatusEl = document.getElementById('dbBpStatus');
    if (liveBpEl) liveBpEl.innerText = bp;
    
    if (bpProgressEl) {
      const sys = parseInt(bp.split('/')[0]) || 120;
      const pct = Math.min(100, Math.max(10, Math.round((sys / 150) * 100)));
      bpProgressEl.style.width = `${pct}%`;
    }
    
    if (bpStatusEl) {
      const sys = parseInt(bp.split('/')[0]) || 120;
      const dia = parseInt(bp.split('/')[1]) || 80;
      if (sys < 120 && dia < 80) {
        bpStatusEl.innerText = 'Optimal Condition';
        bpStatusEl.className = 'vital-status text-teal';
      } else if (sys < 130 && dia < 80) {
        bpStatusEl.innerText = 'Elevated BP';
        bpStatusEl.className = 'vital-status text-teal';
      } else {
        bpStatusEl.innerText = 'High BP Trend';
        bpStatusEl.className = 'vital-status text-amber';
      }
    }

    // Blood Sugar
    const liveSugarEl = document.getElementById('dbLiveSugar');
    const sugarProgressEl = document.getElementById('dbSugarProgress');
    const sugarStatusEl = document.getElementById('dbSugarStatus');
    if (liveSugarEl) liveSugarEl.innerText = sugar;
    
    if (sugarProgressEl) {
      const val = parseInt(sugar) || 95;
      const pct = Math.min(100, Math.max(10, Math.round((val / 150) * 100)));
      sugarProgressEl.style.width = `${pct}%`;
    }
    
    if (sugarStatusEl) {
      const val = parseInt(sugar) || 95;
      if (val < 100) {
        sugarStatusEl.innerText = 'Normal (Fasting)';
        sugarStatusEl.className = 'vital-status text-teal';
      } else if (val < 126) {
        sugarStatusEl.innerText = 'Prediabetes (Fasting)';
        sugarStatusEl.className = 'vital-status text-amber';
      } else {
        sugarStatusEl.innerText = 'Diabetes Range';
        sugarStatusEl.className = 'vital-status text-amber';
      }
    }

    // Blood Oxygen
    const liveSpO2El = document.getElementById('dbLiveSpO2');
    const spo2ProgressEl = document.getElementById('dbSpO2Progress');
    const spo2StatusEl = document.getElementById('dbSpO2Status');
    if (liveSpO2El) liveSpO2El.innerText = `${spo2}%`;
    
    if (spo2ProgressEl) {
      spo2ProgressEl.style.width = `${spo2}%`;
    }
    
    if (spo2StatusEl) {
      const val = parseInt(spo2) || 98;
      if (val >= 95) {
        spo2StatusEl.innerText = 'Healthy Oxygenation';
        spo2StatusEl.className = 'vital-status text-teal';
      } else {
        spo2StatusEl.innerText = 'Low Oxygen Warning';
        spo2StatusEl.className = 'vital-status text-amber';
      }
    }
  }

  function insertVitalsTableRow(bpm, bp, sugar, spo2) {
    if (!vitalsTableBody) return;
    const dateStr = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
    const tr = document.createElement('tr');
    tr.style.animation = "fadeIn 0.4s ease";
    tr.innerHTML = `
      <td>${dateStr}</td>
      <td>${bpm} BPM</td>
      <td>${bp}</td>
      <td>${sugar} mg/dL</td>
      <td>${spo2}%</td>
    `;
    vitalsTableBody.insertBefore(tr, vitalsTableBody.firstChild);
  }

  // File Ingestion logic
  const vitalsDropzone = document.getElementById('vitalsDropzone');
  const vitalsFileInput = document.getElementById('vitalsFileInput');
  const vitalsUploadProgress = document.getElementById('vitalsUploadProgress');
  const vitalsUploadBar = document.getElementById('vitalsUploadBar');
  const vitalsUploadPct = document.getElementById('vitalsUploadPct');
  const vitalsUploadStatus = document.getElementById('vitalsUploadStatus');

  if (vitalsDropzone && vitalsFileInput) {
    vitalsDropzone.addEventListener('click', () => {
      vitalsFileInput.click();
    });

    vitalsDropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      vitalsDropzone.classList.add('dragover');
    });

    vitalsDropzone.addEventListener('dragleave', () => {
      vitalsDropzone.classList.remove('dragover');
    });

    vitalsDropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      vitalsDropzone.classList.remove('dragover');
      const files = e.dataTransfer?.files;
      if (files && files.length > 0) {
        handleMockVitalsUpload(files[0].name);
      }
    });

    vitalsFileInput.addEventListener('change', () => {
      const files = vitalsFileInput.files;
      if (files && files.length > 0) {
        handleMockVitalsUpload(files[0].name);
      }
    });
  }

  function handleMockVitalsUpload(fileName) {
    if (!vitalsUploadProgress || !vitalsUploadBar || !vitalsUploadPct || !vitalsUploadStatus) return;

    vitalsUploadProgress.classList.remove('hide');
    vitalsUploadStatus.innerText = `Reading ${fileName}...`;
    vitalsUploadBar.style.width = '0%';
    vitalsUploadPct.innerText = '0%';

    let pct = 0;
    const interval = setInterval(() => {
      pct += 20;
      vitalsUploadBar.style.width = `${pct}%`;
      vitalsUploadPct.innerText = `${pct}%`;

      if (pct === 40) {
        vitalsUploadStatus.innerText = 'Parsing CSV columns...';
      } else if (pct === 80) {
        vitalsUploadStatus.innerText = 'Ingesting parsed data...';
      } else if (pct >= 100) {
        clearInterval(interval);
        vitalsUploadStatus.innerText = 'Ingestion Succeeded!';
        
        setTimeout(() => {
          // Ingest mock values from file
          const mockBpm = 74;
          const mockBp = "122/82";
          const mockSugar = 98;
          const mockSpO2 = 99;

          updateVitalsDisplay(mockBpm, mockBp, mockSugar, mockSpO2);
          insertVitalsTableRow(mockBpm, mockBp, mockSugar, mockSpO2);
          closeVitalsModal();
        }, 800);
      }
    }, 200);
  }

  function resetVitalsForm() {
    vitalsUploadProgress?.classList.add('hide');
    if (manualVitalsForm) manualVitalsForm.reset();
  }



  // Chatbot logic
  const chatForm = document.getElementById('chatForm');
  const chatInputText = document.getElementById('chatInputText');
  const chatMessages = document.getElementById('chatMessages');

  // Preloaded dynamic answers
  const qa = {
    "blood sugar": "To lower fasting blood sugar naturally: 1. Walk for 15-20 mins post meals. 2. Limit refined carbohydrates and high-glycemic sweeteners. 3. Integrate dietary fibers (e.g. oats, chia seeds, broccoli). 4. Maintain hydration.",
    "diet": "A heart-healthy diet plan focuses on: 1. Omega-3 rich fats (salmon, flaxseeds). 2. High potassium foods (leafy greens, avocados) which regulate blood pressure. 3. Low-sodium intakes (below 1500mg daily limit).",
    "bp trend": "Your blood pressure trend is stable. Resting measurements average 120/80 mmHg. This sits perfectly in the optimal clinical category. Keep monitoring twice weekly.",
    "hydration": "Adults should aim for 2.5 to 3.5 Liters of water daily. Ensure consistent intake, especially when taking oral medications like antibiotics.",
    "hello": "Hello! I am your automated wellness counselor. How can I help you check medication details or nutritional schedules?",
    "hi": "Hi there! I am ready to advise you. Ask me about blood pressure, sugar levels, or medication dosages."
  };

  if (chatForm && chatInputText && chatMessages) {
    chatForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const query = chatInputText.value.trim();
      if (!query) return;

      // Add patient message
      addMessage(query, 'patient', '👤');
      chatInputText.value = '';

      // Processing loader
      setTimeout(() => {
        respondToQuery(query);
      }, 700);
    });

    // Handle suggestion button clicks
    const suggestButtons = document.querySelectorAll('.chat-suggest-btn');
    suggestButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const query = btn.getAttribute('data-query') || '';
        addMessage(query, 'patient', '👤');
        setTimeout(() => {
          respondToQuery(query);
        }, 700);
      });
    });
  }

  function addMessage(text, type, avatar) {
    if (!chatMessages) return;
    const msgDiv = document.createElement('div');
    msgDiv.className = `chat-msg msg-${type}`;
    msgDiv.innerHTML = `
      <div class="msg-avatar">${avatar}</div>
      <div class="msg-bubble">${text}</div>
    `;
    chatMessages.appendChild(msgDiv);
    
    // Auto Scroll
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function respondToQuery(query) {
    const qLower = query.toLowerCase();
    let response = "I understand your question regarding health optimization. While I parse your inquiry, please recall that general lifestyle adjustments should be cross-referenced with your clinic coordinator. Can I assist you with details on 'blood sugar', 'diets', or 'BP Trends'?";

    for (const key in qa) {
      if (qLower.includes(key)) {
        response = qa[key];
        break;
      }
    }

    addMessage(response, 'ai', '🤖');
  }
</script>
