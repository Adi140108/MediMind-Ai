---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="MediMind AI – Book Specialist Appointment">
  <Header />

  <main class="doctors-page section">
    <div class="lc-bg-glow"></div>
    <div class="lc-bg-glow-2"></div>
    
    <div class="container">
      <!-- Success Notification Toast -->
      <div id="bookingToast" class="toast-notification hide">
        <span class="toast-icon">✓</span>
        <div class="toast-content">
          <strong>Appointment Requested</strong>
          <span class="body-sm" id="toastMessage">Your time slot has been reserved. Check your Secure Records for your active ticket.</span>
        </div>
        <button class="toast-close" id="toastCloseBtn">×</button>
      </div>

      <!-- Page Header -->
      <div class="page-header-row text-left">
        <div>
          <span class="badge badge-teal animate-pulse-soft">Appointments Portal</span>
          <h1 class="display-lg page-title">Consult Clinical Specialists.</h1>
          <p class="body-md text-slate">Connect with vetted clinical doctors and schedule in-person or telehealth consultations instantly. All appointments sync with your Secure Vault.</p>
        </div>
      </div>

      <!-- Search & Filters Toolbar -->
      <div class="toolbar-box glass-card">
        <div class="search-group">
          <span class="search-icon">🔍</span>
          <input 
            type="text" 
            id="doctorSearchInput" 
            class="form-control search-input" 
            placeholder="Search by specialist name, disease focus, or keyword..."
          />
        </div>
        <div class="filter-pills-row">
          <button class="filter-pill active" data-dept="all">All Specialties</button>
          <button class="filter-pill" data-dept="Cardiology">Cardiology</button>
          <button class="filter-pill" data-dept="Endocrinology">Endocrinology</button>
          <button class="filter-pill" data-dept="Neurology">Neurology</button>
          <button class="filter-pill" data-dept="Pulmonology">Pulmonology</button>
        </div>
      </div>

      <!-- Doctors Grid -->
      <div class="doctors-grid" id="doctorsGrid">
        
        <!-- Doctor Card 1 -->
        <div class="glass-card doctor-card" data-name="Evelyn Ross" data-dept="Cardiology">
          <div class="doc-card-main">
            <!-- Doctor SVG Avatar -->
            <div class="doc-avatar bg-blue-tint">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-blue">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
              </svg>
              <div class="doc-active-dot"></div>
            </div>
            
            <div class="doc-info">
              <span class="caption-mono font-xs">Cardiology Specialist</span>
              <h3 class="doc-name">Dr. Evelyn Ross, MD</h3>
              <p class="body-sm doc-credentials">Harvard Medical · 12 Yrs Experience</p>
              <div class="doc-rating">
                <span class="star-rating">★ 4.9</span>
                <span class="review-count">(124 reviews)</span>
              </div>
            </div>
          </div>

          <div class="doc-booking-section">
            <span class="scheduler-label">Select Consult Time (Today):</span>
            <div class="time-slots-grid" data-doctor="Dr. Evelyn Ross" data-dept="Cardiology">
              <button class="time-slot-btn" data-time="09:00 AM">09:00 AM</button>
              <button class="time-slot-btn" data-time="11:30 AM">11:30 AM</button>
              <button class="time-slot-btn" data-time="02:00 PM">02:00 PM</button>
              <button class="time-slot-btn" data-time="04:30 PM">04:30 PM</button>
            </div>
            <button class="btn btn-primary book-action-btn" disabled>Book Consultation</button>
          </div>
        </div>

        <!-- Doctor Card 2 -->
        <div class="glass-card doctor-card" data-name="Marcus Vance" data-dept="Endocrinology">
          <div class="doc-card-main">
            <!-- Doctor SVG Avatar -->
            <div class="doc-avatar bg-teal-tint">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-teal">
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                <path d="m12 6-2 3h4l-2 3"/>
                <path d="M12 12v6"/>
              </svg>
              <div class="doc-active-dot"></div>
            </div>
            
            <div class="doc-info">
              <span class="caption-mono font-xs">Endocrine Health</span>
              <h3 class="doc-name">Dr. Marcus Vance, MD</h3>
              <p class="body-sm doc-credentials">Stanford Medicine · 9 Yrs Experience</p>
              <div class="doc-rating">
                <span class="star-rating">★ 4.8</span>
                <span class="review-count">(98 reviews)</span>
              </div>
            </div>
          </div>

          <div class="doc-booking-section">
            <span class="scheduler-label">Select Consult Time (Tomorrow):</span>
            <div class="time-slots-grid" data-doctor="Dr. Marcus Vance" data-dept="Endocrinology">
              <button class="time-slot-btn" data-time="10:00 AM">10:00 AM</button>
              <button class="time-slot-btn" data-time="12:00 PM">12:00 PM</button>
              <button class="time-slot-btn" data-time="03:30 PM">03:30 PM</button>
              <button class="time-slot-btn" data-time="05:00 PM">05:00 PM</button>
            </div>
            <button class="btn btn-primary book-action-btn" disabled>Book Consultation</button>
          </div>
        </div>

        <!-- Doctor Card 3 -->
        <div class="glass-card doctor-card" data-name="Clara Thorne" data-dept="Neurology">
          <div class="doc-card-main">
            <!-- Doctor SVG Avatar -->
            <div class="doc-avatar bg-blue-tint">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-blue">
                <path d="M12 2a10 10 0 0 0-10 10c0 5.52 4.48 10 10 10s10-4.48 10-10S17.52 2 12 2zm1 14h-2v-2h2v2zm0-4h-2V7h2v5z"/>
              </svg>
              <div class="doc-active-dot"></div>
            </div>
            
            <div class="doc-info">
              <span class="caption-mono font-xs">Neurology Specialist</span>
              <h3 class="doc-name">Dr. Clara Thorne, PhD</h3>
              <p class="body-sm doc-credentials">Johns Hopkins · 15 Yrs Experience</p>
              <div class="doc-rating">
                <span class="star-rating">★ 4.9</span>
                <span class="review-count">(156 reviews)</span>
              </div>
            </div>
          </div>

          <div class="doc-booking-section">
            <span class="scheduler-label">Select Consult Time (Today):</span>
            <div class="time-slots-grid" data-doctor="Dr. Clara Thorne" data-dept="Neurology">
              <button class="time-slot-btn" data-time="08:30 AM">08:30 AM</button>
              <button class="time-slot-btn" data-time="11:00 AM">11:00 AM</button>
              <button class="time-slot-btn" data-time="01:30 PM">01:30 PM</button>
              <button class="time-slot-btn" data-time="04:00 PM">04:00 PM</button>
            </div>
            <button class="btn btn-primary book-action-btn" disabled>Book Consultation</button>
          </div>
        </div>

        <!-- Doctor Card 4 -->
        <div class="glass-card doctor-card" data-name="Adrian Sterling" data-dept="Pulmonology">
          <div class="doc-card-main">
            <!-- Doctor SVG Avatar -->
            <div class="doc-avatar bg-teal-tint">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-teal">
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                <path d="M12 8v8"/>
                <path d="M8 12h8"/>
              </svg>
              <div class="doc-active-dot"></div>
            </div>
            
            <div class="doc-info">
              <span class="caption-mono font-xs">Pulmonary Medicine</span>
              <h3 class="doc-name">Dr. Adrian Sterling, MD</h3>
              <p class="body-sm doc-credentials">Penn Medicine · 8 Yrs Experience</p>
              <div class="doc-rating">
                <span class="star-rating">★ 4.7</span>
                <span class="review-count">(84 reviews)</span>
              </div>
            </div>
          </div>

          <div class="doc-booking-section">
            <span class="scheduler-label">Select Consult Time (Monday):</span>
            <div class="time-slots-grid" data-doctor="Dr. Adrian Sterling" data-dept="Pulmonology">
              <button class="time-slot-btn" data-time="09:30 AM">09:30 AM</button>
              <button class="time-slot-btn" data-time="12:30 PM">12:30 PM</button>
              <button class="time-slot-btn" data-time="03:00 PM">03:00 PM</button>
              <button class="time-slot-btn" data-time="05:30 PM">05:30 PM</button>
            </div>
            <button class="btn btn-primary book-action-btn" disabled>Book Consultation</button>
          </div>
        </div>

      </div>

      <!-- No Doctors Found State -->
      <div id="noDoctorsState" class="no-results-state glass-card hide">
        <span class="no-results-icon">🩺</span>
        <h3 class="display-sm">No Specialist Found.</h3>
        <p class="body-sm">We couldn't find any specialist matching your search query. Try choosing another filter or resetting your keywords.</p>
        <button class="btn btn-secondary" id="resetFiltersBtn">Reset Search Filters</button>
      </div>

    </div>
  </main>

  <!-- Reservation Overlay Modal -->
  <div class="modal-overlay hide" id="bookingModal">
    <div class="modal-card glass-card">
      <div class="modal-header">
        <h3 class="display-sm modal-title">Confirm Appointment</h3>
        <button class="modal-close" id="modalCloseBtn">×</button>
      </div>
      
      <div class="modal-body">
        <div class="receipt-summary">
          <div class="receipt-row">
            <span class="receipt-label">Specialist:</span>
            <strong class="receipt-value" id="modalDocName">Dr. Evelyn Ross</strong>
          </div>
          <div class="receipt-row">
            <span class="receipt-label">Department:</span>
            <span class="receipt-value font-mono font-xs" id="modalDocDept">Cardiology</span>
          </div>
          <div class="receipt-row">
            <span class="receipt-label">Time Slot:</span>
            <strong class="receipt-value text-teal" id="modalDocTime">11:30 AM</strong>
          </div>
          <div class="receipt-row">
            <span class="receipt-label">Patient:</span>
            <span class="receipt-value">John Doe (ID: #MM-3094)</span>
          </div>
          <div class="receipt-row border-top">
            <span class="receipt-label">Reference ID:</span>
            <span class="receipt-value font-mono font-xs label-teal" id="modalReceiptRef">MM-TX-8493A</span>
          </div>
        </div>

        <div class="hipaa-notice">
          <span class="notice-bullet">🔒</span>
          <p class="caption">This reservation is processed using secure, end-to-end encrypted clinical parameters. Your slot is held for 15 minutes.</p>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary flex-1" id="modalCancelBtn">Cancel</button>
        <button class="btn btn-primary flex-1" id="modalConfirmBtn">Confirm Reservation</button>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .doctors-page {
    padding-top: 110px;
    background-color: var(--color-canvas-soft);
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 120px);
  }

  .lc-bg-glow {
    position: absolute;
    top: 5%;
    left: -5%;
    width: 350px;
    height: 350px;
    background-color: rgba(37, 99, 235, 0.05);
    filter: blur(120px);
    pointer-events: none;
    border-radius: 50%;
  }

  .lc-bg-glow-2 {
    position: absolute;
    bottom: 10%;
    right: -5%;
    width: 350px;
    height: 350px;
    background-color: rgba(20, 184, 166, 0.04);
    filter: blur(120px);
    pointer-events: none;
    border-radius: 50%;
  }

  .page-header-row {
    border-bottom: 1px solid var(--color-canvas-soft-2);
    padding-bottom: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .page-title {
    margin-bottom: 4px;
  }

  /* Toolbar */
  .toolbar-box {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-canvas);
    margin-bottom: var(--space-xl);
    gap: var(--space-lg);
  }

  .search-group {
    position: relative;
    flex-grow: 1;
    max-width: 480px;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.85rem;
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding-left: 38px;
    height: 40px;
    border-radius: var(--radius-pill);
    border-color: var(--color-canvas-soft-2);
  }

  .filter-pills-row {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .filter-pill {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 6px 16px;
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-canvas-soft-2);
    color: var(--color-body);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .filter-pill:hover, .filter-pill.active {
    background-color: rgba(37, 99, 235, 0.08);
    border-color: var(--color-primary);
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Grid of Doctors */
  .doctors-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .doctor-card {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    background-color: var(--color-canvas);
    text-align: left;
  }

  .doc-card-main {
    display: flex;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
    align-items: flex-start;
  }

  .doc-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
  }

  .bg-blue-tint {
    background-color: rgba(37, 99, 235, 0.08);
  }

  .bg-teal-tint {
    background-color: rgba(20, 184, 166, 0.08);
  }

  .text-blue { color: var(--color-primary); }
  .text-teal { color: var(--color-accent); }

  .doc-active-dot {
    position: absolute;
    bottom: 2px;
    right: 2px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--color-success);
    border: 2px solid var(--color-canvas);
  }

  .doc-info {
    display: flex;
    flex-direction: column;
  }

  .doc-name {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 2px 0;
  }

  .doc-credentials {
    color: var(--color-body);
  }

  .doc-rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
  }

  .star-rating {
    font-size: 0.85rem;
    color: var(--color-warning);
    font-weight: 600;
  }

  .review-count {
    font-size: 0.775rem;
    color: var(--color-mute);
  }

  /* Booking section */
  .doc-booking-section {
    border-top: 1px solid var(--color-canvas-soft-2);
    padding-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .scheduler-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .time-slots-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
  }

  .time-slot-btn {
    font-family: var(--font-sans);
    font-size: 0.725rem;
    font-weight: 500;
    padding: 8px 4px;
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-canvas-soft-2);
    color: var(--color-body);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: var(--transition-smooth);
    text-align: center;
  }

  .time-slot-btn:hover {
    background-color: var(--color-canvas-soft-2);
    border-color: #cbd5e1;
    color: var(--color-ink);
  }

  .time-slot-btn.active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
    font-weight: 600;
  }

  .book-action-btn {
    width: 100%;
    justify-content: center;
    height: 40px;
  }

  .book-action-btn:disabled {
    background-color: var(--color-canvas-soft-2);
    border-color: var(--color-canvas-soft-2);
    color: var(--color-mute);
    cursor: not-allowed;
    transform: none !important;
    box-shadow: none !important;
  }

  /* Toast Notification */
  .toast-notification {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-success);
    padding: var(--space-md);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-level-5);
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    z-index: 1100;
    width: 380px;
    text-align: left;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .toast-notification.hide {
    display: none;
    transform: translateY(20px);
    opacity: 0;
  }

  .toast-icon {
    width: 22px;
    height: 22px;
    background-color: var(--color-success);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .toast-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .toast-close {
    background: none;
    border: none;
    font-size: 1.2rem;
    color: var(--color-mute);
    cursor: pointer;
    margin-left: auto;
    line-height: 1;
  }

  /* Modal Overlay */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1050;
    transition: opacity 0.25s ease;
  }

  .modal-overlay.hide {
    display: none;
    pointer-events: none;
  }

  .modal-card {
    width: 100%;
    max-width: 440px;
    background-color: var(--color-canvas);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-canvas-soft-2);
    padding-bottom: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .modal-close {
    background: none;
    border: none;
    font-size: 1.4rem;
    cursor: pointer;
    color: var(--color-mute);
    transition: var(--transition-smooth);
    line-height: 1;
  }

  .modal-close:hover {
    color: var(--color-ink);
  }

  .receipt-summary {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    background-color: var(--color-canvas-soft);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-canvas-soft-2);
    margin-bottom: var(--space-md);
  }

  .receipt-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }

  .receipt-row.border-top {
    border-top: 1px solid var(--color-canvas-soft-2);
    padding-top: var(--space-sm);
    margin-top: 4px;
  }

  .receipt-label {
    color: var(--color-mute);
  }

  .receipt-value {
    color: var(--color-ink);
  }

  .hipaa-notice {
    display: flex;
    gap: 8px;
    background-color: rgba(37, 99, 235, 0.04);
    border: 1px solid rgba(37, 99, 235, 0.1);
    padding: 10px;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-lg);
  }

  .notice-bullet {
    font-size: 0.95rem;
  }

  .modal-footer {
    display: flex;
    gap: var(--space-md);
  }

  .flex-1 { flex: 1; }

  /* Empty state */
  .no-results-state {
    padding: var(--space-5xl) var(--space-lg);
    background-color: var(--color-canvas);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    max-width: 600px;
    margin: 0 auto;
  }

  .no-results-state.hide {
    display: none;
  }

  .no-results-icon {
    font-size: 2.5rem;
  }

  /* Responsive details */
  @media (max-width: 840px) {
    .doctors-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .toolbar-box {
      flex-direction: column;
      align-items: stretch;
    }
    
    .search-group {
      max-width: 100%;
    }
    
    .filter-pills-row {
      overflow-x: auto;
      padding-bottom: 4px;
    }
  }
</style>

<script>
  // Filter and search variables
  const searchInput = document.getElementById('doctorSearchInput');
  const filterPills = document.querySelectorAll('.filter-pill');
  const docCards = document.querySelectorAll('.doctor-card');
  const doctorsGrid = document.getElementById('doctorsGrid');
  const noDoctorsState = document.getElementById('noDoctorsState');
  const resetFiltersBtn = document.getElementById('resetFiltersBtn');

  // Filter state
  let currentSearch = '';
  let currentDept = 'all';

  function applyFilters() {
    let visibleCount = 0;
    docCards.forEach(card => {
      const cardElement = card;
      const name = cardElement.getAttribute('data-name')?.toLowerCase() || '';
      const dept = cardElement.getAttribute('data-dept') || '';
      
      const matchesSearch = name.includes(currentSearch) || dept.toLowerCase().includes(currentSearch);
      const matchesDept = currentDept === 'all' || dept === currentDept;

      if (matchesSearch && matchesDept) {
        cardElement.style.display = 'flex';
        visibleCount++;
      } else {
        cardElement.style.display = 'none';
      }
    });

    if (visibleCount === 0) {
      doctorsGrid?.classList.add('hide');
      noDoctorsState?.classList.remove('hide');
    } else {
      doctorsGrid?.classList.remove('hide');
      noDoctorsState?.classList.add('hide');
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      currentSearch = searchInput.value.trim().toLowerCase();
      applyFilters();
    });
  }

  filterPills.forEach(pill => {
    pill.addEventListener('click', () => {
      filterPills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      currentDept = pill.getAttribute('data-dept') || 'all';
      applyFilters();
    });
  });

  if (resetFiltersBtn) {
    resetFiltersBtn.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      currentSearch = '';
      currentDept = 'all';
      filterPills.forEach(p => p.classList.remove('active'));
      document.querySelector('[data-dept="all"]')?.classList.add('active');
      applyFilters();
    });
  }

  // Time slots & Booking triggers
  let selectedSlot = null;

  const docCardsList = document.querySelectorAll('.doctor-card');
  docCardsList.forEach(card => {
    const slots = card.querySelectorAll('.time-slot-btn');
    const bookBtn = card.querySelector('.book-action-btn');

    slots.forEach(slot => {
      slot.addEventListener('click', () => {
        // Deselect other slots in the grid
        slots.forEach(s => s.classList.remove('active'));
        
        const slotBtn = slot;
        slotBtn.classList.add('active');
        selectedSlot = slotBtn;
        
        // Enable book button
        if (bookBtn) bookBtn.removeAttribute('disabled');
      });
    });

    if (bookBtn) {
      bookBtn.addEventListener('click', () => {
        if (!selectedSlot) return;
        const doctorName = card.getAttribute('data-name') || '';
        const dept = card.getAttribute('data-dept') || '';
        const time = selectedSlot.getAttribute('data-time') || '';
        
        openBookingModal(doctorName, dept, time);
      });
    }
  });

  // Modal actions
  const bookingModal = document.getElementById('bookingModal');
  const modalCloseBtn = document.getElementById('modalCloseBtn');
  const modalCancelBtn = document.getElementById('modalCancelBtn');
  const modalConfirmBtn = document.getElementById('modalConfirmBtn');
  
  const modalDocName = document.getElementById('modalDocName');
  const modalDocDept = document.getElementById('modalDocDept');
  const modalDocTime = document.getElementById('modalDocTime');
  const modalReceiptRef = document.getElementById('modalReceiptRef');

  function generateRefId() {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
    let token = 'MM-TX-';
    for (let i = 0; i < 5; i++) {
      token += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    return token;
  }

  let pendingDoc = '';
  let pendingDept = '';
  let pendingTime = '';
  let pendingRef = '';

  function openBookingModal(doctor, department, time) {
    pendingDoc = doctor;
    pendingDept = department;
    pendingTime = time;
    pendingRef = generateRefId();

    if (modalDocName) modalDocName.innerText = `Dr. ${doctor}, MD`;
    if (modalDocDept) modalDocDept.innerText = department;
    if (modalDocTime) modalDocTime.innerText = time;
    if (modalReceiptRef) modalReceiptRef.innerText = pendingRef;

    bookingModal?.classList.remove('hide');
  }

  function closeBookingModal() {
    bookingModal?.classList.add('hide');
  }

  if (modalCloseBtn) modalCloseBtn.addEventListener('click', closeBookingModal);
  if (modalCancelBtn) modalCancelBtn.addEventListener('click', closeBookingModal);

  // Confirm booking
  const toast = document.getElementById('bookingToast');
  const toastMsg = document.getElementById('toastMessage');
  const toastClose = document.getElementById('toastCloseBtn');

  if (modalConfirmBtn) {
    modalConfirmBtn.addEventListener('click', () => {
      closeBookingModal();
      
      // Store in session storage to showcase in the Vault
      const activeBookings = JSON.parse(sessionStorage.getItem('activeBookings') || '[]');
      activeBookings.push({
        doctor: `Dr. ${pendingDoc}, MD`,
        dept: pendingDept,
        time: pendingTime,
        ref: pendingRef,
        date: pendingDept === 'Endocrinology' ? 'Tomorrow' : (pendingDept === 'Pulmonology' ? 'Monday' : 'Today')
      });
      sessionStorage.setItem('activeBookings', JSON.stringify(activeBookings));

      // Show toast notification
      if (toast && toastMsg) {
        toastMsg.innerText = `Successfully booked Dr. ${pendingDoc} for ${pendingTime} (${pendingDept === 'Endocrinology' ? 'Tomorrow' : (pendingDept === 'Pulmonology' ? 'Monday' : 'Today')}). Reference Token: ${pendingRef}.`;
        toast.classList.remove('hide');
        
        // Auto hide toast after 8 seconds
        setTimeout(() => {
          toast.classList.add('hide');
        }, 8000);
      }

      // Reset selection
      if (selectedSlot) {
        selectedSlot.classList.remove('active');
        selectedSlot = null;
      }
      
      const activeBookBtn = document.querySelector('.book-action-btn:not([disabled])');
      if (activeBookBtn) activeBookBtn.setAttribute('disabled', 'true');
    });
  }

  if (toastClose) {
    toastClose.addEventListener('click', () => {
      toast?.classList.add('hide');
    });
  }
</script>
